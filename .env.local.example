# ─── Client config (safe to expose — these are public Firebase identifiers) ───
# VITE_ vars are compiled into the browser bundle. ONLY put non-secret values here.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# ─── Server-side secrets (NEVER VITE_ prefixed — must stay out of the bundle) ───
# In local dev, the Vite proxy (vite.config.ts) injects these into outbound
# /api/anthropic and /api/esv requests from this Node process.
# In production, set them as Firebase Functions secrets instead:
#   firebase functions:secrets:set CLAUDE_API_KEY
#   firebase functions:secrets:set ESV_API_KEY
CLAUDE_API_KEY=your-claude-api-key
ESV_API_KEY=your-esv-api-key

# Note: Planning Center credentials are entered per-church in-app (stored in
# Firestore, forwarded through the /api/planningcenter proxy) — no env var needed.
